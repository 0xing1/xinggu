---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category?: string;
  tags?: string[];
  lang?: 'zh' | 'en';
  faq?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  tags = [],
  lang = 'zh',
  faq = [],
} = Astro.props;

// 获取所有文章用于前后导航和相关推荐
const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex(p => p.data.title === title);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// 获取相关文章（同分类或同标签）
const relatedPosts = sortedPosts
  .filter(p => p.data.title !== title)
  .filter(p => p.data.category === category || p.data.tags.some(t => tags.includes(t)))
  .slice(0, 3);

// 多语言文本
const text = {
  zh: {
    published: '发布于',
    updated: '更新于',
    category: '分类',
    tags: '标签',
    backToBlog: '返回博客',
    share: '分享',
    tableOfContents: '目录',
    readingTime: '阅读时间',
    minutes: '分钟',
    prevPost: '上一篇',
    nextPost: '下一篇',
    relatedPosts: '相关文章',
    relatedDescription: '探索更多相关内容',
    copyCode: '复制',
    copied: '已复制!',
  },
  en: {
    published: 'Published on',
    updated: 'Updated on',
    category: 'Category',
    tags: 'Tags',
    backToBlog: 'Back to Blog',
    share: 'Share',
    tableOfContents: 'Table of Contents',
    readingTime: 'Reading time',
    minutes: 'min',
    prevPost: 'Previous',
    nextPost: 'Next',
    relatedPosts: 'Related Posts',
    relatedDescription: 'Explore more related content',
    copyCode: 'Copy',
    copied: 'Copied!',
  },
};

const t = text[lang];

// 格式化日期
const formatDate = (date: Date) => {
  return date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// 计算阅读时间（假设每分钟200字）
const contentLength = description.length;
const readingTime = Math.max(1, Math.ceil(contentLength / 200));

// JSON-LD 结构化数据
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: heroImage || new URL('/og-image.svg', Astro.site).href,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: '星谷',
    url: new URL('/about', Astro.site).href,
    jobTitle: '全栈开发者',
    knowsAbout: ['Astro', 'Vue', 'TypeScript', '前端开发'],
  },
  publisher: {
    '@type': 'Organization',
    name: '星谷的技术博客',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-image.svg', Astro.site).href,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
  ...(category && { articleSection: category }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
};

// FAQPage Schema (if FAQ data provided)
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
} : null;

// 估算字数
const wordCount = 500; // 简化估算
---

<BaseLayout title={title} description={description} lang={lang}>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Article OG Metadata -->
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content="星谷" />
    {category && <meta property="article:section" content={category} />}
    {tags.length > 0 && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    {heroImage && <meta property="og:image" content={heroImage} />}
  </Fragment>

  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <!-- Article Header -->
  <section class="article-header">
    <div class="container-narrow">
      <nav class="breadcrumb">
        <a href={`/${lang === 'en' ? 'en/' : ''}`}>{lang === 'zh' ? '首页' : 'Home'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`}>{lang === 'zh' ? '博客' : 'Blog'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <span>{title}</span>
      </nav>

      {category && (
        <a href={`/${lang === 'en' ? 'en/' : ''}blog/category/${category}`} class="article-category">
          {category}
        </a>
      )}

      <h1 class="article-title">{title}</h1>

      <p class="article-description">{description}</p>

      <div class="article-meta">
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={pubDate.toISOString()}>
            {t.published} {formatDate(pubDate)}
          </time>
        </div>

        {updatedDate && (
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            <span>{t.updated} {formatDate(updatedDate)}</span>
          </div>
        )}

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{t.readingTime} {readingTime} {t.minutes}</span>
        </div>

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>{wordCount} {lang === 'zh' ? '字' : 'words'}</span>
        </div>
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <a href={`/${lang === 'en' ? 'en/' : ''}blog/tag/${tag}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Hero Image -->
  {heroImage && (
    <section class="article-hero">
      <div class="container-narrow">
        <img src={heroImage} alt={title} class="hero-image" loading="lazy" decoding="async" width="1200" height="630" />
      </div>
    </section>
  )}

  <!-- Article Content -->
  <section class="article-content">
    <div class="container-narrow">
      <div class="content-wrapper">
        <!-- Table of Contents -->
        <aside class="toc-sidebar">
          <div class="toc-container">
            <h3 class="toc-title">{t.tableOfContents}</h3>
            <nav class="toc-nav" id="toc-nav">
              <!-- Table of contents will be generated by JavaScript -->
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <article class="article-body" id="article-body">
          <slot />
        </article>
      </div>
    </div>
  </section>

  <!-- Article Footer -->
  <section class="article-footer">
    <div class="container-narrow">
      <div class="footer-actions">
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`} class="back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          {t.backToBlog}
        </a>

        <div class="share-buttons">
          <span class="share-label">{t.share}:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label="Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label="LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <button class="share-button" id="copy-link-btn" aria-label="Copy link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Prev/Next Navigation -->
      <div class="post-navigation">
        {prevPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${prevPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link prev">
            <span class="nav-label">← {t.prevPost}</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${nextPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link next">
            <span class="nav-label">{t.nextPost} →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <h3>{t.relatedPosts}</h3>
          <p class="related-description">{t.relatedDescription}</p>
          <div class="related-grid">
            {relatedPosts.map(post => (
              <a href={`/${lang === 'en' ? 'en/' : ''}blog/${post.id.replace(/^(zh|en)\//, '')}`} class="related-card">
                <div class="related-info">
                  {post.data.category && <span class="related-category">{post.data.category}</span>}
                  <h4>{post.data.title}</h4>
                  <p>{post.data.description}</p>
                  <time>{formatDate(post.data.pubDate)}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* Article Header */
  .article-header {
    padding: var(--space-12) 0 var(--space-8);
    background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg-tertiary) 100%);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .breadcrumb a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  .breadcrumb svg {
    color: var(--color-text-tertiary);
  }

  .breadcrumb span {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .article-category {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .article-category:hover {
    background-color: var(--color-primary);
    color: white;
    text-decoration: none;
  }

  .article-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
  }

  .article-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    max-width: 700px;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .meta-item svg {
    flex-shrink: 0;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-primary);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    border-radius: var(--radius-full);
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
  }

  .tag:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }

  /* Hero Image */
  .article-hero {
    padding: var(--space-8) 0;
    background-color: var(--color-bg-primary);
  }

  .hero-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
  }

  /* Article Content */
  .article-content {
    padding: var(--space-12) 0;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  /* Table of Contents */
  .toc-sidebar {
    position: sticky;
    top: 100px;
  }

  .toc-container {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .toc-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .toc-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .toc-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    border-left: 2px solid transparent;
  }

  .toc-link:hover {
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .toc-link.active {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  .toc-link.level-3 {
    padding-left: var(--space-6);
    font-size: var(--text-xs);
  }

  /* Article Body */
  .article-body {
    max-width: none;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .article-body :global(h2) {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .article-body :global(h3) {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .article-body :global(h4) {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .article-body :global(p) {
    margin-bottom: var(--space-6);
    color: var(--color-text-secondary);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .article-body :global(li) {
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
  }

  .article-body :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-6) 0;
    background-color: var(--color-primary-light);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .article-body :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .article-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background-color: var(--color-bg-tertiary);
    color: var(--color-secondary);
    padding: 0.2em 0.4em;
    border-radius: var(--radius-sm);
    font-weight: 500;
  }

  .article-body :global(pre) {
    background-color: var(--color-bg-inverse);
    color: var(--color-text-inverse);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    overflow-x: auto;
    margin-bottom: var(--space-6);
    position: relative;
    box-shadow: var(--shadow-lg);
  }

  .article-body :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-6) 0;
    box-shadow: var(--shadow-md);
  }

  .article-body :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-primary-light);
    text-underline-offset: 3px;
    transition: all var(--transition-fast);
  }

  .article-body :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  .article-body :global(strong) {
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .article-body :global(hr) {
    height: 1px;
    background-color: var(--color-border);
    margin: var(--space-8) 0;
    border: none;
  }

  /* Article Footer */
  .article-footer {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-12);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .back-link:hover {
    gap: var(--space-3);
    text-decoration: none;
  }

  .share-buttons {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .share-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .share-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border-radius: var(--radius-lg);
    transition: all var(--transition-fast);
  }

  .share-button:hover {
    background-color: var(--color-primary);
    color: white;
    transform: translateY(-2px);
  }

  /* Reading Progress Bar */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));
    z-index: 9999;
    transition: width 100ms ease-out;
  }

  /* Post Navigation */
  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .post-navigation .nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .post-navigation .nav-link:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .post-navigation .nav-link.next {
    text-align: right;
  }

  .post-navigation .nav-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    font-weight: 500;
  }

  .post-navigation .nav-title {
    font-size: var(--text-base);
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* Related Posts */
  .related-posts {
    text-align: center;
  }

  .related-posts h3 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-2);
  }

  .related-description {
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-8);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    text-align: left;
  }

  .related-card {
    display: block;
    padding: var(--space-4);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .related-card:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .related-category {
    display: inline-block;
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-2);
  }

  .related-card h4 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-card time {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* Code Copy Button */
  .code-copy-btn {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    cursor: pointer;
    opacity: 0;
    transition: all var(--transition-fast);
  }

  pre:hover .code-copy-btn {
    opacity: 1;
  }

  .code-copy-btn:hover {
    background-color: var(--color-primary);
    color: white;
  }

  .code-copy-btn.copied {
    background-color: var(--color-success);
    color: white;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .content-wrapper {
      grid-template-columns: 1fr;
    }

    .toc-sidebar {
      display: none;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .article-header {
      padding: var(--space-8) 0 var(--space-6);
    }

    .article-title {
      font-size: var(--text-3xl);
    }

    .article-description {
      font-size: var(--text-base);
    }

    .article-meta {
      flex-direction: column;
      gap: var(--space-3);
    }

    .footer-actions {
      flex-direction: column;
      gap: var(--space-4);
    }

    .share-buttons {
      width: 100%;
      justify-content: center;
    }

    .post-navigation {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Reading Progress Bar
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = (scrollTop / docHeight) * 100;
        progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
      };
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    // Copy Link Button
    const copyLinkBtn = document.getElementById('copy-link-btn');
    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          copyLinkBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
          setTimeout(() => {
            copyLinkBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`;
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    }

    // Code Copy Buttons
    document.querySelectorAll('pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'code-copy-btn';
      btn.textContent = 'Copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (code) {
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            setTimeout(() => {
              btn.textContent = 'Copy';
              btn.classList.remove('copied');
            }, 2000);
          } catch (err) {
            console.error('Failed to copy code:', err);
          }
        }
      });
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });

    // Generate Table of Contents
    const tocNav = document.getElementById('toc-nav');
    const articleBody = document.querySelector('.article-body');

    if (tocNav && articleBody) {
      const headings = articleBody.querySelectorAll('h2, h3');
      const tocLinks: HTMLAnchorElement[] = [];

      headings.forEach((heading, index) => {
        const id = `heading-${index}`;
        heading.id = id;

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent || '';
        link.className = `toc-link ${heading.tagName === 'H3' ? 'level-3' : ''}`;

        link.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.getElementById(id);
          if (target) {
            target.scrollIntoView({
              behavior: 'smooth',
              block: 'start',
            });
          }
        });

        tocNav.appendChild(link);
        tocLinks.push(link);
      });

      // Highlight active TOC item on scroll
      const observerOptions = {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = tocNav.querySelector(`a[href="#${id}"]`);
          if (link) {
            if (entry.isIntersecting) {
              tocLinks.forEach((l) => l.classList.remove('active'));
              link.classList.add('active');
            }
          }
        });
      }, observerOptions);

      headings.forEach((heading) => {
        observer.observe(heading);
      });
    }

    // Image Lightbox
    document.querySelectorAll('.article-body img').forEach((img) => {
      img.addEventListener('click', () => {
        const overlay = document.createElement('div');
        overlay.style.cssText = `
          position: fixed; top: 0; left: 0; width: 100%; height: 100%;
          background: rgba(0,0,0,0.9); display: flex; align-items: center;
          justify-content: center; z-index: 10000; cursor: pointer;
        `;
        const clone = img.cloneNode() as HTMLImageElement;
        clone.style.cssText = 'max-width: 90%; max-height: 90vh; object-fit: contain;';
        overlay.appendChild(clone);
        overlay.addEventListener('click', () => overlay.remove());
        document.body.appendChild(overlay);
      });
      img.style.cursor = 'zoom-in';
    });
  });
</script>