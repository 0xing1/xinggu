  }

  .article-body :global(pre code) {
    background: none;
    color: inherit;
    padding: 0;
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    margin: var(--space-6) 0;
