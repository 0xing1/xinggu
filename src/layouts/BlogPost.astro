    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-secondary);
    border: none;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
  }

  pre:hover .code-copy-btn { opacity: 1; }
  .code-copy-btn:hover { background-color: var(--color-primary); color: white; }
  .code-copy-btn.copied { background-color: var(--color-success); color: white; }

  /* Responsive */
  @media (max-width: 1024px) {
    .content-wrapper { grid-template-columns: 1fr; }
    .toc-sidebar { display: none; }
    .related-grid { grid-template-columns: repeat(2, 1fr); }
    .floating-actions { display: none; }
  }

  @media (max-width: 768px) {
    .article-header { padding: var(--space-8) 0 var(--space-6); }
    .article-title { font-size: var(--text-3xl); }
    .article-description { font-size: var(--text-base); }
    .article-meta { flex-direction: column; gap: var(--space-3); }
    .footer-actions { flex-direction: column; gap: var(--space-4); }
    .share-buttons { width: 100%; justify-content: center; }
    .post-navigation { grid-template-columns: 1fr; }
    .related-grid { grid-template-columns: 1fr; }
    .mobile-actions { display: flex; }
    .article-footer { padding-bottom: 5rem; }
    .author-card { flex-direction: column; text-align: center; }
    .inline-actions { justify-content: center; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const postSlug = document.querySelector('[data-post]')?.getAttribute('data-post') || 'unknown';
    const likeKey = `likes_${postSlug}`;
    const bookmarkKey = `bookmark_${postSlug}`;

    // === Like System (localStorage) ===
    function getLikeCount() {
      return parseInt(localStorage.getItem(likeKey) || '0', 10);
    }

    function isLiked() {
      return localStorage.getItem(`${likeKey}_active`) === 'true';
    }

    function toggleLike() {
      const currentlyLiked = isLiked();
      const count = getLikeCount();
      if (currentlyLiked) {
        localStorage.setItem(likeKey, String(Math.max(0, count - 1)));
        localStorage.removeItem(`${likeKey}_active`);
      } else {
        localStorage.setItem(likeKey, String(count + 1));
        localStorage.setItem(`${likeKey}_active`, 'true');
      }
      updateLikeUI();
    }

    function updateLikeUI() {
      const count = getLikeCount();
      const liked = isLiked();
      // Floating bar
      const floatBtn = document.getElementById('float-like-btn');
      const floatCount = document.getElementById('float-like-count');
      if (floatBtn) floatBtn.classList.toggle('active', liked);
      if (floatCount) floatCount.textContent = count > 0 ? String(count) : '';
      // Inline
      const inlineBtn = document.getElementById('inline-like-btn');
      const inlineCount = document.getElementById('inline-like-count');
      if (inlineBtn) inlineBtn.classList.toggle('active', liked);
      if (inlineCount) inlineCount.textContent = count > 0 ? String(count) : '';
      // Mobile
      const mobileBtn = document.getElementById('mobile-like-btn');
      const mobileCount = document.getElementById('mobile-like-count');
      if (mobileBtn) mobileBtn.classList.toggle('active', liked);
      if (mobileCount) mobileCount.textContent = count > 0 ? String(count) : '';
    }

    document.querySelectorAll('.like-btn').forEach(btn => {
      btn.addEventListener('click', toggleLike);
    });

    // === Bookmark System (localStorage) ===
    function isBookmarked() {
      return localStorage.getItem(bookmarkKey) === 'true';
    }

    function toggleBookmark() {
      const currentlySaved = isBookmarked();
      if (currentlySaved) {
        localStorage.removeItem(bookmarkKey);
      } else {
        localStorage.setItem(bookmarkKey, 'true');
      }
      updateBookmarkUI();
    }

    function updateBookmarkUI() {
      const saved = isBookmarked();
      const floatBtn = document.getElementById('float-bookmark-btn');
      if (floatBtn) floatBtn.classList.toggle('active', saved);
      const inlineBtn = document.getElementById('inline-bookmark-btn');
      if (inlineBtn) {
        inlineBtn.classList.toggle('active', saved);
        const labelSpan = inlineBtn.querySelector('span:not(.action-count)');
        if (labelSpan) labelSpan.textContent = saved ? '已收藏' : '收藏';
      }
      const mobileBtn = document.getElementById('mobile-bookmark-btn');
      if (mobileBtn) mobileBtn.classList.toggle('active', saved);
    }

    document.querySelectorAll('.bookmark-btn').forEach(btn => {
      btn.addEventListener('click', toggleBookmark);
    });

    // Init UI
    updateLikeUI();
    updateBookmarkUI();

    // === Floating Actions Visibility ===
    const floatingActions = document.getElementById('floating-actions');
    if (floatingActions) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            floatingActions.classList.toggle('visible', entry.isIntersecting);
          });
        },
        { threshold: 0.1 }
      );
      const articleBody = document.querySelector('.article-body');
      if (articleBody) observer.observe(articleBody);
    }

    // === Copy Link ===
    const copyLinkBtn = document.getElementById('copy-link-btn');
    const floatCopyBtn = document.getElementById('float-copy-btn');
    async function copyLink() {
      try {
        await navigator.clipboard.writeText(window.location.href);
        const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        if (copyLinkBtn) { copyLinkBtn.innerHTML = checkSvg; setTimeout(() => { copyLinkBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`; }, 2000); }
        if (floatCopyBtn) { floatCopyBtn.innerHTML = checkSvg; setTimeout(() => { floatCopyBtn.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`; }, 2000); }
      } catch (err) { console.error('Failed to copy:', err); }
    }
    copyLinkBtn?.addEventListener('click', copyLink);
    floatCopyBtn?.addEventListener('click', copyLink);

    // === Mobile Share ===
    document.getElementById('mobile-share-btn')?.addEventListener('click', () => {
      if (navigator.share) {
        navigator.share({ title: document.title, url: window.location.href });
      } else {
        copyLink();
      }
    });

    // === Mobile TOC Drawer ===
    const tocDrawer = document.getElementById('toc-drawer');
    const tocOverlay = document.getElementById('toc-drawer-overlay');
    const tocDrawerNav = document.getElementById('toc-drawer-nav');
    const tocDrawerClose = document.getElementById('toc-drawer-close');

    // Clone desktop TOC links to mobile drawer
    const desktopTocLinks = document.querySelectorAll('#toc-nav .toc-link');
    desktopTocLinks.forEach(link => {
      const clone = link.cloneNode(true);
      tocDrawerNav?.appendChild(clone);
    });

    function openTocDrawer() {
      tocDrawer?.classList.add('open');
      tocOverlay?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeTocDrawer() {
      tocDrawer?.classList.remove('open');
      tocOverlay?.classList.remove('open');
      document.body.style.overflow = '';
    }

    document.getElementById('mobile-toc-btn')?.addEventListener('click', openTocDrawer);
    tocDrawerClose?.addEventListener('click', closeTocDrawer);
    tocOverlay?.addEventListener('click', closeTocDrawer);

    // === Reading Progress Bar ===
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      const updateProgress = () => {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = (scrollTop / docHeight) * 100;
        progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
      };
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }

    // === Code Copy Buttons ===
    document.querySelectorAll('pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'code-copy-btn';
      btn.textContent = 'Copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (code) {
          try {
            await navigator.clipboard.writeText(code.textContent || '');
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
          } catch (err) { console.error('Failed to copy code:', err); }
        }
      });
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });

    // === Generate Table of Contents ===
    const tocNav = document.getElementById('toc-nav');
    const articleBody = document.querySelector('.article-body');

    if (tocNav && articleBody) {
      const headings = articleBody.querySelectorAll('h2, h3');
      const tocLinks: HTMLAnchorElement[] = [];

      headings.forEach((heading, index) => {
        const id = `heading-${index}`;
        heading.id = id;

        const link = document.createElement('a');
        link.href = `#${id}`;
        link.textContent = heading.textContent || '';
        link.className = `toc-link ${heading.tagName === 'H3' ? 'level-3' : ''}`;

        link.addEventListener('click', (e) => {
          e.preventDefault();
          const target = document.getElementById(id);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            closeTocDrawer();
          }
        });

        tocNav.appendChild(link);
        tocLinks.push(link);
      });

      // Highlight active TOC item on scroll
      const observerOptions = {
        rootMargin: '-80px 0px -80% 0px',
        threshold: 0,
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          const link = tocNav.querySelector(`a[href="#${id}"]`);
          if (link && entry.isIntersecting) {
            tocLinks.forEach((l) => l.classList.remove('active'));
            link.classList.add('active');
            // Sync mobile drawer
            const drawerLink = tocDrawerNav?.querySelector(`a[href="#${id}"]`);
            tocDrawerNav?.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
            drawerLink?.classList.add('active');
          }
        });
      }, observerOptions);

      headings.forEach((heading) => observer.observe(heading));
    }

    // === Image Lightbox ===
    document.querySelectorAll('.article-body img').forEach((img) => {
      img.addEventListener('click', () => {
        const overlay = document.createElement('div');
        overlay.style.cssText = `position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.9);display:flex;align-items:center;justify-content:center;z-index:10000;cursor:pointer;`;
        const clone = img.cloneNode() as HTMLImageElement;
        clone.style.cssText = 'max-width:90%;max-height:90vh;object-fit:contain;';
        overlay.appendChild(clone);
        overlay.addEventListener('click', () => overlay.remove());
        document.body.appendChild(overlay);
      });
      (img as HTMLElement).style.cursor = 'zoom-in';
    });

    // === Giscus Comments ===
    const giscusContainer = document.getElementById('giscus-container');
    if (giscusContainer) {
      const theme = document.documentElement.getAttribute('data-theme') || 'light';
      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'xinggu/blog-comments');
      script.setAttribute('data-repo-id', '');
      script.setAttribute('data-category', 'Announcements');
      script.setAttribute('data-category-id', '');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-strict', '0');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-emit-metadata', '0');
      script.setAttribute('data-input-position', 'top');
      script.setAttribute('data-theme', theme === 'dark' ? 'dark' : 'light');
      script.setAttribute('data-lang', document.documentElement.lang || 'zh-CN');
      script.setAttribute('data-loading', 'lazy');
      script.crossOrigin = 'anonymous';
      script.async = true;
      giscusContainer.appendChild(script);

      // Update giscus theme when site theme changes
      const observer = new MutationObserver(() => {
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        const iframe = document.querySelector<HTMLIFrameElement>('iframe.giscus-frame');
        iframe?.contentWindow?.postMessage(
          { giscus: { setConfig: { theme: currentTheme === 'dark' ? 'dark' : 'light' } } },
          'https://giscus.app'
        );
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    }
  });
</script>
