---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category?: string;
  tags?: string[];
  lang?: 'zh' | 'en';
  faq?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  tags = [],
  lang = 'zh',
  faq = [],
} = Astro.props;

// 获取所有文章用于前后导航和相关推荐
const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex(p => p.data.title === title);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// 获取相关文章（同分类或同标签）
const relatedPosts = sortedPosts
  .filter(p => p.data.title !== title)
  .filter(p => p.data.category === category || p.data.tags.some(t => tags.includes(t)))
  .slice(0, 3);

// 多语言文本
const text = {
  zh: {
    published: '发布于',
    updated: '更新于',
    category: '分类',
    tags: '标签',
    backToBlog: '返回博客',
    share: '分享',
    tableOfContents: '目录',
    readingTime: '阅读时间',
    minutes: '分钟',
    prevPost: '上一篇',
    nextPost: '下一篇',
    relatedPosts: '相关文章',
    relatedDescription: '探索更多相关内容',
    copyCode: '复制',
    copied: '已复制!',
    like: '点赞',
    bookmark: '收藏',
    bookmarked: '已收藏',
    comments: '评论',
    author: '关于作者',
    authorBio: '全栈开发者，热爱技术，分享前端开发、编程技巧和技术见解。',
    viewProfile: '查看主页',
    shareWechat: '微信',
    shareWeibo: '微博',
    scanToShare: '扫码分享到微信',
  },
  en: {
    published: 'Published on',
    updated: 'Updated on',
    category: 'Category',
    tags: 'Tags',
    backToBlog: 'Back to Blog',
    share: 'Share',
    tableOfContents: 'Table of Contents',
    readingTime: 'Reading time',
    minutes: 'min',
    prevPost: 'Previous',
    nextPost: 'Next',
    relatedPosts: 'Related Posts',
    relatedDescription: 'Explore more related content',
    copyCode: 'Copy',
    copied: 'Copied!',
    like: 'Like',
    bookmark: 'Bookmark',
    bookmarked: 'Saved',
    comments: 'Comments',
    author: 'About the Author',
    authorBio: 'Full-stack developer passionate about technology, sharing web dev insights and tips.',
    viewProfile: 'View Profile',
    shareWechat: 'WeChat',
    shareWeibo: 'Weibo',
    scanToShare: 'Scan to share on WeChat',
  },
};

const t = text[lang];

// 格式化日期
const formatDate = (date: Date) => {
  return date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// 估算字数和阅读时间（基于描述长度的合理估算）
// 注意：在 SSG 中无法直接获取渲染后的正文长度，使用描述作为基准
const estimatedWordCount = Math.max(300, description.length * 8);
const readingTime = Math.max(1, Math.ceil(estimatedWordCount / (lang === 'zh' ? 400 : 200)));

// 文章唯一 ID（用于 localStorage key）
const postSlug = Astro.url.pathname.replace(/\/$/, '').split('/').pop() || 'unknown';

// JSON-LD 结构化数据
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: heroImage || new URL('/og-image.svg', Astro.site).href,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: new URL('/about', Astro.site).href,
    jobTitle: lang === 'zh' ? '全栈开发者' : 'Full-Stack Developer',
    knowsAbout: ['Astro', 'Vue', 'TypeScript', 'Frontend Development'],
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.title,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-image.svg', Astro.site).href,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
  wordCount: estimatedWordCount,
  ...(category && { articleSection: category }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
};

// FAQPage Schema (if FAQ data provided)
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
} : null;
---

<BaseLayout title={title} description={description} lang={lang}>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Article OG Metadata -->
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={SITE.author} />
    {category && <meta property="article:section" content={category} />}
    {tags.length > 0 && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    {heroImage && <meta property="og:image" content={heroImage} />}
    <meta name="twitter:card" content={heroImage ? 'summary_large_image' : 'summary'} />
  </Fragment>

  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <!-- Floating Action Bar (desktop sidebar) -->
  <aside class="floating-actions" id="floating-actions" aria-label={t.share}>
    <button class="float-btn like-btn" id="float-like-btn" aria-label={t.like} data-post={postSlug}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
      <span class="float-count" id="float-like-count">0</span>
    </button>
    <button class="float-btn bookmark-btn" id="float-bookmark-btn" aria-label={t.bookmark} data-post={postSlug}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
    <div class="float-divider"></div>
    <a class="float-btn" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a class="float-btn" href={`https://service.weibo.com/share/share.php?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" aria-label={t.shareWeibo}>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM9.05 17.219c-.384.616-1.208.884-1.829.602-.612-.279-.793-.991-.406-1.593.379-.595 1.176-.86 1.796-.584.625.28.825.978.439 1.575zm1.27-1.627c-.141.237-.449.353-.689.253-.236-.09-.307-.361-.158-.596.148-.234.456-.351.692-.243.239.09.315.36.155.586zm.176-2.719c-1.893-.494-4.036.45-4.857 2.118-.836 1.704-.026 3.591 1.886 4.21 1.983.642 4.318-.341 5.132-2.179.8-1.793-.201-3.642-2.161-4.149zm7.563-1.224c-.346-.105-.583-.176-.402-.636.396-1.005.436-1.872.009-2.496-.803-1.172-3.007-1.112-5.578-.033 0 0-.798.351-.594-.285.391-1.243.332-2.283-.283-2.887-1.418-1.395-5.189.053-8.435 3.244C.931 11.972 0 14.147 0 16.025c0 3.628 4.667 5.843 9.243 5.843 5.996 0 9.975-3.489 9.975-6.259 0-1.673-1.412-2.624-2.117-2.916z"/></svg>
    </a>
    <button class="float-btn" id="float-copy-btn" aria-label="Copy link">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
    </button>
  </aside>

  <!-- Mobile Bottom Action Bar -->
  <div class="mobile-actions" id="mobile-actions">
    <button class="mobile-action-btn" id="mobile-like-btn" data-post={postSlug}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span id="mobile-like-count">0</span>
    </button>
    <button class="mobile-action-btn" id="mobile-bookmark-btn" data-post={postSlug}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
    </button>
    <button class="mobile-action-btn" id="mobile-share-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
    </button>
    <button class="mobile-action-btn" id="mobile-toc-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile TOC Drawer -->
  <div class="toc-drawer" id="toc-drawer">
    <div class="toc-drawer-header">
      <h3>{t.tableOfContents}</h3>
      <button class="toc-drawer-close" id="toc-drawer-close" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="toc-drawer-nav" id="toc-drawer-nav"></nav>
  </div>
  <div class="toc-drawer-overlay" id="toc-drawer-overlay"></div>

  <!-- Article Header -->
  <section class="article-header">
    <div class="container-narrow">
      <nav class="breadcrumb">
        <a href={`/${lang === 'en' ? 'en/' : ''}`}>{lang === 'zh' ? '首页' : 'Home'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`}>{lang === 'zh' ? '博客' : 'Blog'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <span>{title}</span>
      </nav>

      {category && (
        <a href={`/${lang === 'en' ? 'en/' : ''}blog/category/${category}`} class="article-category">
          {category}
        </a>
      )}

      <h1 class="article-title">{title}</h1>

      <p class="article-description">{description}</p>

      <div class="article-meta">
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={pubDate.toISOString()}>
            {t.published} {formatDate(pubDate)}
          </time>
        </div>

        {updatedDate && (
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            <span>{t.updated} {formatDate(updatedDate)}</span>
          </div>
        )}

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{t.readingTime} {readingTime} {t.minutes}</span>
        </div>

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>{estimatedWordCount} {lang === 'zh' ? '字' : 'words'}</span>
        </div>
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <a href={`/${lang === 'en' ? 'en/' : ''}blog/tag/${tag}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Hero Image -->
  {heroImage && (
    <section class="article-hero">
      <div class="container-narrow">
        <img src={heroImage} alt={title} class="hero-image" loading="lazy" decoding="async" width="1200" height="630" />
      </div>
    </section>
  )}

  <!-- Article Content -->
  <section class="article-content">
    <div class="container-narrow">
      <div class="content-wrapper">
        <!-- Table of Contents -->
        <aside class="toc-sidebar">
          <div class="toc-container">
            <h3 class="toc-title">{t.tableOfContents}</h3>
            <nav class="toc-nav" id="toc-nav">
              <!-- Table of contents will be generated by JavaScript -->
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <article class="article-body" id="article-body">
          <slot />
        </article>
      </div>
    </div>
  </section>

  <!-- Article Footer -->
  <section class="article-footer">
    <div class="container-narrow">
      <!-- Author Card -->
      <div class="author-card">
        <div class="author-avatar">
          <svg width="64" height="64" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="60" r="60" fill="url(#author-grad)"/>
            <circle cx="60" cy="45" r="20" fill="white" opacity="0.9"/>
            <path d="M30 95C30 75 45 60 60 60C75 60 90 75 90 95" fill="white" opacity="0.9"/>
            <defs><linearGradient id="author-grad" x1="0" y1="0" x2="120" y2="120"><stop stop-color="var(--color-primary)"/><stop offset="1" stop-color="var(--color-secondary)"/></linearGradient></defs>
          </svg>
        </div>
        <div class="author-info">
          <h4>{SITE.author}</h4>
          <p>{t.authorBio}</p>
          <a href={`/${lang === 'en' ? 'en/' : ''}about`} class="author-link">{t.viewProfile} →</a>
        </div>
      </div>

      <!-- Inline Actions -->
      <div class="inline-actions">
        <button class="action-btn like-btn" id="inline-like-btn" data-post={postSlug}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          <span>{t.like}</span>
          <span class="action-count" id="inline-like-count">0</span>
        </button>
        <button class="action-btn bookmark-btn" id="inline-bookmark-btn" data-post={postSlug}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          <span>{t.bookmark}</span>
        </button>
      </div>

      <div class="footer-actions">
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`} class="back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          {t.backToBlog}
        </a>

        <div class="share-buttons">
          <span class="share-label">{t.share}:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label="Twitter">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href={`https://service.weibo.com/share/share.php?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label={t.shareWeibo}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M10.098 20.323c-3.977.391-7.414-1.406-7.672-4.02-.259-2.609 2.759-5.047 6.74-5.441 3.979-.394 7.413 1.404 7.671 4.018.259 2.6-2.759 5.049-6.739 5.443zM9.05 17.219c-.384.616-1.208.884-1.829.602-.612-.279-.793-.991-.406-1.593.379-.595 1.176-.86 1.796-.584.625.28.825.978.439 1.575zm1.27-1.627c-.141.237-.449.353-.689.253-.236-.09-.307-.361-.158-.596.148-.234.456-.351.692-.243.239.09.315.36.155.586zm.176-2.719c-1.893-.494-4.036.45-4.857 2.118-.836 1.704-.026 3.591 1.886 4.21 1.983.642 4.318-.341 5.132-2.179.8-1.793-.201-3.642-2.161-4.149zm7.563-1.224c-.346-.105-.583-.176-.402-.636.396-1.005.436-1.872.009-2.496-.803-1.172-3.007-1.112-5.578-.033 0 0-.798.351-.594-.285.391-1.243.332-2.283-.283-2.887-1.418-1.395-5.189.053-8.435 3.244C.931 11.972 0 14.147 0 16.025c0 3.628 4.667 5.843 9.243 5.843 5.996 0 9.975-3.489 9.975-6.259 0-1.673-1.412-2.624-2.117-2.916z"/></svg>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener noreferrer" class="share-button" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <button class="share-button" id="copy-link-btn" aria-label="Copy link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Prev/Next Navigation -->
      <div class="post-navigation">
        {prevPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${prevPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link prev">
            <span class="nav-label">← {t.prevPost}</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${nextPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link next">
            <span class="nav-label">{t.nextPost} →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <h3>{t.relatedPosts}</h3>
          <p class="related-description">{t.relatedDescription}</p>
          <div class="related-grid">
            {relatedPosts.map(post => (
              <a href={`/${lang === 'en' ? 'en/' : ''}blog/${post.id.replace(/^(zh|en)\//, '')}`} class="related-card">
                <div class="related-info">
                  {post.data.category && <span class="related-category">{post.data.category}</span>}
                  <h4>{post.data.title}</h4>
                  <p>{post.data.description}</p>
                  <time>{formatDate(post.data.pubDate)}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Giscus Comments -->
      <div class="comments-section" id="comments-section">
        <h3 class="comments-title">{t.comments}</h3>
        <div class="giscus" id="giscus-container"></div>
      </div>
    </div>
  </section>
</BaseLayout>

