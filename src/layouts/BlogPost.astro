---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  category?: string;
  tags?: string[];
  lang?: 'zh' | 'en';
  faq?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  category,
  tags = [],
  lang = 'zh',
  faq = [],
} = Astro.props;

// 获取所有文章用于前后导航和相关推荐
const allPosts = await getCollection('blog', ({ data }) => data.lang === lang);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = sortedPosts.findIndex(p => p.data.title === title);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

// 获取相关文章（同分类或同标签）
const relatedPosts = sortedPosts
  .filter(p => p.data.title !== title)
  .filter(p => p.data.category === category || p.data.tags.some(t => tags.includes(t)))
  .slice(0, 3);

// 多语言文本
const text = {
  zh: {
    published: '发布于',
    updated: '更新于',
    category: '分类',
    tags: '标签',
    backToBlog: '返回博客',
    share: '分享',
    tableOfContents: '目录',
    readingTime: '阅读时间',
    minutes: '分钟',
    prevPost: '上一篇',
    nextPost: '下一篇',
    relatedPosts: '相关文章',
    relatedDescription: '探索更多相关内容',
    copyCode: '复制',
    copied: '已复制!',
    author: '关于作者',
    authorBio: '全栈开发者，热爱技术，分享前端开发、编程技巧和技术见解。',
    viewProfile: '查看主页',
  },
  en: {
    published: 'Published on',
    updated: 'Updated on',
    category: 'Category',
    tags: 'Tags',
    backToBlog: 'Back to Blog',
    share: 'Share',
    tableOfContents: 'Table of Contents',
    readingTime: 'Reading time',
    minutes: 'min',
    prevPost: 'Previous',
    nextPost: 'Next',
    relatedPosts: 'Related Posts',
    relatedDescription: 'Explore more related content',
    copyCode: 'Copy',
    copied: 'Copied!',
    author: 'About the Author',
    authorBio: 'Full-stack developer passionate about technology, sharing web dev insights and tips.',
    viewProfile: 'View Profile',
  },
};

const t = text[lang];

// 移除未使用的社交功能变量
// const postSlug = ... (已删除)

// 格式化日期
const formatDate = (date: Date) => {
  return date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

// 估算字数和阅读时间（基于描述长度的合理估算）
// 注意：在 SSG 中无法直接获取渲染后的正文长度，使用描述作为基准
const estimatedWordCount = Math.max(300, description.length * 8);
const readingTime = Math.max(1, Math.ceil(estimatedWordCount / (lang === 'zh' ? 400 : 200)));

// JSON-LD 结构化数据
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: heroImage || new URL('/og-image.svg', Astro.site).href,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author,
    url: new URL('/about', Astro.site).href,
    jobTitle: lang === 'zh' ? '全栈开发者' : 'Full-Stack Developer',
    knowsAbout: ['Astro', 'Vue', 'TypeScript', 'Frontend Development'],
  },
  publisher: {
    '@type': 'Organization',
    name: SITE.title,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/og-image.svg', Astro.site).href,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
  wordCount: estimatedWordCount,
  ...(category && { articleSection: category }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
};

// FAQPage Schema (if FAQ data provided)
const faqSchema = faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
} : null;
---

<BaseLayout title={title} description={description} lang={lang}>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Article OG Metadata -->
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={SITE.author} />
    {category && <meta property="article:section" content={category} />}
    {tags.length > 0 && tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    {heroImage && <meta property="og:image" content={heroImage} />}
    <meta name="twitter:card" content={heroImage ? 'summary_large_image' : 'summary'} />
  </Fragment>

  <!-- Reading Progress Bar -->
  <div class="reading-progress" id="reading-progress"></div>

  <!-- Mobile TOC Drawer -->
  <div class="toc-drawer" id="toc-drawer">
    <div class="toc-drawer-header">
      <h3>{t.tableOfContents}</h3>
      <button class="toc-drawer-close" id="toc-drawer-close" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="toc-drawer-nav" id="toc-drawer-nav"></nav>
  </div>
  <div class="toc-drawer-overlay" id="toc-drawer-overlay"></div>

  <!-- Article Header -->
  <section class="article-header">
    <div class="container-narrow">
      <nav class="breadcrumb">
        <a href={`/${lang === 'en' ? 'en/' : ''}`}>{lang === 'zh' ? '首页' : 'Home'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`}>{lang === 'zh' ? '博客' : 'Blog'}</a>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
        <span>{title}</span>
      </nav>

      {category && (
        <a href={`/${lang === 'en' ? 'en/' : ''}blog/category/${category}`} class="article-category">
          {category}
        </a>
      )}

      <h1 class="article-title">{title}</h1>

      <p class="article-description">{description}</p>

      <div class="article-meta">
        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={pubDate.toISOString()}>
            {t.published} {formatDate(pubDate)}
          </time>
        </div>

        {updatedDate && (
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="23 4 23 10 17 10"/>
              <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
            </svg>
            <span>{t.updated} {formatDate(updatedDate)}</span>
          </div>
        )}

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span>{t.readingTime} {readingTime} {t.minutes}</span>
        </div>

        <div class="meta-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span>{estimatedWordCount} {lang === 'zh' ? '字' : 'words'}</span>
        </div>
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <a href={`/${lang === 'en' ? 'en/' : ''}blog/tag/${tag}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Hero Image -->
  {heroImage && (
    <section class="article-hero">
      <div class="container-narrow">
        <img src={heroImage} alt={title} class="hero-image" loading="lazy" decoding="async" width="1200" height="630" />
      </div>
    </section>
  )}

  <!-- Article Content -->
  <section class="article-content">
    <div class="container-narrow">
      <div class="content-wrapper">
        <!-- Table of Contents -->
        <aside class="toc-sidebar">
          <div class="toc-container">
            <h3 class="toc-title">{t.tableOfContents}</h3>
            <nav class="toc-nav" id="toc-nav">
              <!-- Table of contents will be generated by JavaScript -->
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <article class="article-body" id="article-body">
          <slot />
        </article>
      </div>
    </div>
  </section>

  <!-- Article Footer -->
  <section class="article-footer">
    <div class="container-narrow">
      <!-- Author Card -->
      <div class="author-card">
        <div class="author-avatar">
          <svg width="64" height="64" viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="60" cy="60" r="60" fill="url(#author-grad)"/>
            <circle cx="60" cy="45" r="20" fill="white" opacity="0.9"/>
            <path d="M30 95C30 75 45 60 60 60C75 60 90 75 90 95" fill="white" opacity="0.9"/>
            <defs><linearGradient id="author-grad" x1="0" y1="0" x2="120" y2="120"><stop stop-color="var(--color-primary)"/><stop offset="1" stop-color="var(--color-secondary)"/></linearGradient></defs>
          </svg>
        </div>
        <div class="author-info">
          <h4>{SITE.author}</h4>
          <p>{t.authorBio}</p>
          <a href={`/${lang === 'en' ? 'en/' : ''}about`} class="author-link">{t.viewProfile} →</a>
        </div>
      </div>

      <div class="footer-actions">
        <a href={`/${lang === 'en' ? 'en/' : ''}blog`} class="back-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          {t.backToBlog}
        </a>

        <button class="share-button" id="copy-link-btn" aria-label="Copy link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span class="copy-label">{t.share}</span>
        </button>
      </div>

      <!-- Prev/Next Navigation -->
      <div class="post-navigation">
        {prevPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${prevPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link prev">
            <span class="nav-label">← {t.prevPost}</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        )}
        {nextPost && (
          <a href={`/${lang === 'en' ? 'en/' : ''}blog/${nextPost.id.replace(/^(zh|en)\//, '')}`} class="nav-link next">
            <span class="nav-label">{t.nextPost} →</span>
            <span class="nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </div>

      <!-- Related Posts -->
      {relatedPosts.length > 0 && (
        <div class="related-posts">
          <h3>{t.relatedPosts}</h3>
          <p class="related-description">{t.relatedDescription}</p>
          <div class="related-grid">
            {relatedPosts.map(post => (
              <a href={`/${lang === 'en' ? 'en/' : ''}blog/${post.id.replace(/^(zh|en)\//, '')}`} class="related-card">
                <div class="related-info">
                  {post.data.category && <span class="related-category">{post.data.category}</span>}
                  <h4>{post.data.title}</h4>
                  <p>{post.data.description}</p>
                  <time>{formatDate(post.data.pubDate)}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  /* Author Card */
  .author-card {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    margin-bottom: var(--space-8);
  }

  .author-avatar {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .author-avatar svg {
    width: 100%;
    height: 100%;
  }

  .author-info h4 {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: var(--space-1);
  }

  .author-info p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }

  .author-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
  }

  .author-link:hover {
    text-decoration: underline;
  }

  /* TOC Drawer (mobile) */
  .toc-drawer {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    max-height: 60vh;
    background: var(--color-bg-primary);
    border-top: 1px solid var(--color-border);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    z-index: 200;
    overflow-y: auto;
    box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .toc-drawer.open {
    display: block;
    transform: translateY(0);
  }

  .toc-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-6);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    background: var(--color-bg-primary);
  }

  .toc-drawer-header h3 {
    font-size: var(--text-base);
    font-weight: 600;
    margin: 0;
  }

  .toc-drawer-close {
    background: none;
    border: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    padding: var(--space-1);
  }

  .toc-drawer-nav {
    padding: var(--space-4) var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .toc-drawer-nav .toc-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    border-left: 2px solid transparent;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .toc-drawer-nav .toc-link:hover {
    background: var(--color-bg-tertiary);
    color: var(--color-text-primary);
  }

  .toc-drawer-nav .toc-link.active {
    background: var(--color-primary-light);
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  .toc-drawer-nav .toc-link.level-3 {
    padding-left: var(--space-6);
    font-size: var(--text-xs);
  }

  .toc-drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 199;
  }

  .toc-drawer-overlay.open {
    display: block;
  }

  /* Article Header */
  .article-header {
    padding: var(--space-12) 0 var(--space-8);
    background: linear-gradient(135deg, var(--color-bg-secondary) 0%, var(--color-bg-tertiary) 100%);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    font-size: var(--text-sm);
  }

  .breadcrumb a {
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb svg { color: var(--color-text-tertiary); }
  .breadcrumb span { color: var(--color-text-primary); font-weight: 500; }

  .article-category {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .article-category:hover {
    background-color: var(--color-primary);
    color: white;
    text-decoration: none;
  }

  .article-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .article-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    max-width: 700px;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-bottom: var(--space-6);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .meta-item svg { flex-shrink: 0; }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-bg-primary);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    border-radius: var(--radius-full);
    text-decoration: none;
    border: 1px solid var(--color-border);
    transition: border-color var(--transition-fast), background-color var(--transition-fast), color var(--transition-fast);
  }

  .tag:hover {
    border-color: var(--color-primary);
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }

  /* Hero Image */
  .article-hero {
    padding: var(--space-8) 0;
    background-color: var(--color-bg-primary);
  }

  .hero-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
  }

  /* Article Content */
  .article-content {
    padding: var(--space-12) 0;
  }

  .content-wrapper {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  /* Table of Contents */
  .toc-sidebar {
    position: sticky;
    top: 100px;
  }

  .toc-container {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .toc-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: var(--space-4);
    color: var(--color-text-primary);
  }

  .toc-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .toc-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast), color var(--transition-fast);
    border-left: 2px solid transparent;
  }

  .toc-link:hover {
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .toc-link.active {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    border-left-color: var(--color-primary);
  }

  .toc-link.level-3 {
    padding-left: var(--space-6);
    font-size: var(--text-xs);
  }

  /* Article Body */
  .article-body {
    max-width: none;
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
  }

  .article-body :global(h2) {
    font-size: var(--text-2xl);
    font-weight: 700;
    margin-top: var(--space-12);
    margin-bottom: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    text-wrap: balance;
  }

  .article-body :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .article-body :global(h3) {
    font-size: var(--text-xl);
