---
import BaseLayout from '../layouts/BaseLayout.astro';
import { UI } from '../i18n/translations';

const lang = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
const t = UI[lang];
const homePath = lang === 'en' ? '/en/' : '/';
const blogPath = lang === 'en' ? '/en/blog' : '/blog';
---

<BaseLayout title={`404 — ${t.pageNotFound}`} description={t.pageNotFoundDesc} lang={lang}>
  <section class="not-found">
    <div class="nf-content">
      <div class="nf-code">404</div>
      <h1 class="nf-title">{t.pageNotFound}</h1>
      <p class="nf-desc">{t.pageNotFoundDesc}</p>
      <div class="nf-actions">
        <a href={homePath} class="btn btn-primary">{t.backToHome}</a>
        <a href={blogPath} class="btn btn-outline">{t.blog}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 300px);
    padding: 3rem 1.5rem;
  }

  .nf-content {
    text-align: center;
    max-width: 500px;
  }

  .nf-code {
    font-size: 8rem;
    font-weight: 900;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.15;
    margin-bottom: -1rem;
  }

  .nf-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
  }

  .nf-desc {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    line-height: var(--leading-relaxed);
  }

  .nf-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
