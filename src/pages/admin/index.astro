  <script>
    // Tab 切换
    document.querySelectorAll('.nav-item').forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const tab = item.getAttribute('data-tab');

        // 更新导航状态
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        item.classList.add('active');

        // 更新内容显示
        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.getElementById(tab)?.classList.add('active');
      });
    });

    // 显示消息
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.style.background = type === 'success' ? '#10b981' : '#ef4444';
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // 获取新闻
    document.getElementById('fetch-news-btn')?.addEventListener('click', () => {
      const status = document.getElementById('news-status');
      status.innerHTML = '<p>⏳ 请在终端运行以下命令获取新闻：</p><code>npm run news</code><p class="news-info">运行后刷新页面即可看到新文章</p>';
      showToast('请在终端运行 npm run news');
    });

    // 搜索过滤
    document.getElementById('search-input')?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      document.querySelectorAll('.post-item').forEach(item => {
        const title = item.querySelector('h3').textContent.toLowerCase();
        const desc = item.querySelector('p').textContent.toLowerCase();
        item.style.display = (title.includes(query) || desc.includes(query)) ? 'flex' : 'none';
      });
    });

    // 分类过滤
    document.getElementById('category-filter')?.addEventListener('change', (e) => {
      const category = e.target.value;
      document.querySelectorAll('.post-item').forEach(item => {
        if (category === 'all' || item.dataset.category === category) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    });

    // 语言过滤
    document.getElementById('lang-filter')?.addEventListener('change', (e) => {
      const lang = e.target.value;
      document.querySelectorAll('.post-item').forEach(item => {
        if (lang === 'all' || item.dataset.lang === lang) {
          item.style.display = 'flex';
        } else {
          item.style.display = 'none';
        }
      });
    });

    // 新建文章 - 生成 Markdown 并复制
    document.getElementById('new-post-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const form = e.target;
      const title = form.querySelector('#post-title').value;
      const description = form.querySelector('#post-description').value;
      const lang = form.querySelector('#post-lang').value;
      const category = form.querySelector('#post-category').value;
      const tags = form.querySelector('#post-tags').value;
      const content = form.querySelector('#post-content').value;

      const tagsArray = tags ? tags.split(/[,，]/).map(t => t.trim()).filter(Boolean) : [];
      const slug = title.toLowerCase().replace(/[^\w一-龥]+/g, '-').replace(/^-+|-+$/g, '').substring(0, 50);

      const markdown = `---
title: "${title}"
description: "${description}"
pubDate: ${new Date().toISOString().split('T')[0]}
${category ? `category: "${category}"` : ''}
tags: [${tagsArray.map(t => `"${t}"`).join(', ')}]
lang: "${lang}"
---

${content}
`;

      navigator.clipboard.writeText(markdown).then(() => {
        showToast(`已复制！保存到 src/content/blog/${lang}/${slug}.md`);
      }).catch(() => {
        showToast('复制失败，请手动复制', 'error');
      });
    });

    // 预览功能
    document.getElementById('preview-btn')?.addEventListener('click', () => {
      const content = document.getElementById('post-content').value;
      const previewWindow = window.open('', '_blank');
      previewWindow.document.write(`
        <html>
          <head><title>预览</title><style>body{font-family:sans-serif;max-width:800px;margin:2rem auto;padding:0 1rem;line-height:1.6;}</style></head>
          <body><pre style="white-space:pre-wrap;">${content.replace(/</g, '&lt;')}</pre></body>
        </html>
      `);
    });
  </script>
	<!-- Auth config injected by Astro -->
	<script define:vars={{ passwordHash: DEFAULT_PASSWORD_HASH }}>
		// PBKDF2 hash is one-way — cannot be reversed
		window.__ADMIN__ = { PASSWORD_HASH: passwordHash };
	</script>
	<!-- Auth: PBKDF2 password verify + sessionStorage -->
	<script type="module">
		const { PASSWORD_HASH } = window.__ADMIN__;
		const MAX_ATTEMPTS = 5;
		const LOCKOUT_SECONDS = 30;
		const SESSION_KEY = "admin_authed";

		// === Rate limiting (session only) ===
		let failCount = 0;
		let lockoutUntil = 0;

		function isLocked() {
			if (lockoutUntil > Date.now()) return true;
			if (failCount >= MAX_ATTEMPTS) {
				lockoutUntil = Date.now() + LOCKOUT_SECONDS * 1000;
				return true;
			}
			return false;
		}

		function getLockoutRemaining() {
			return Math.ceil((lockoutUntil - Date.now()) / 1000);
		}

		// === PBKDF2 password verification (Web Crypto API) ===
		async function verifyPassword(password, storedHash) {
			try {
				const parts = storedHash.split(':');
				if (parts.length !== 2) return false;
				const [saltHex, expectedHex] = parts;
				if (!saltHex || !expectedHex) return false;

				const enc = new TextEncoder();
				const salt = enc.encode(saltHex);

				const keyMaterial = await crypto.subtle.importKey(
					'raw', enc.encode(password),
					'PBKDF2', false, ['deriveBits']
				);

				const derivedBits = await crypto.subtle.deriveBits(
					{ name: 'PBKDF2', salt, iterations: 100000, hash: 'SHA-256' },
					keyMaterial, 512
				);

				const hashHex = Array.from(new Uint8Array(derivedBits))
					.map(b => b.toString(16).padStart(2, '0')).join('');

				return hashHex === expectedHex;
			} catch (e) {
				console.debug('Password verification error:', e);
				return false;
			}
		}

		// === Show admin / show login ===
		function showAdmin() {
			const loginPage = document.getElementById('login-page');
			const adminContent = document.getElementById('admin-content');
			if (loginPage) loginPage.style.display = 'none';
			if (adminContent) adminContent.classList.remove('hidden');
		}

		function showLogin() {
			const loginPage = document.getElementById('login-page');
			const adminContent = document.getElementById('admin-content');
			if (loginPage) loginPage.style.display = 'flex';
			if (adminContent) adminContent.classList.add('hidden');
			sessionStorage.removeItem(SESSION_KEY);
		}

		// === Init: check existing session ===
		(function init() {
			if (sessionStorage.getItem(SESSION_KEY) === 'true') {
				showAdmin();
			}
		})();

		// === Login form handler ===
		document.getElementById('login-form')?.addEventListener('submit', async function(e) {
			e.preventDefault();

			const errorEl = document.getElementById('login-error');
			if (errorEl) errorEl.classList.add('hidden');

			// Rate limit check
			if (isLocked()) {
				const remaining = getLockoutRemaining();
				if (errorEl) {
					errorEl.textContent = '尝试次数过多，请 ' + remaining + ' 秒后再试';
					errorEl.classList.remove('hidden');
				}
				return;
			}

			const password = document.getElementById('password').value;
			if (!password) return;

			const submitBtn = this.querySelector('button[type="submit"]');
			const originalText = submitBtn.textContent;
			submitBtn.textContent = '验证中…';
			submitBtn.disabled = true;

			const ok = await verifyPassword(password, PASSWORD_HASH);

			if (ok) {
				sessionStorage.setItem(SESSION_KEY, 'true');
				showAdmin();
				if (errorEl) errorEl.classList.add('hidden');
				document.getElementById('password').value = '';
			} else {
				failCount++;
				if (errorEl) {
					const remaining = MAX_ATTEMPTS - failCount;
					if (remaining > 0) {
						errorEl.textContent = '密码错误，还剩 ' + remaining + ' 次尝试';
					} else {
						errorEl.textContent = '尝试次数过多，请 ' + LOCKOUT_SECONDS + ' 秒后再试';
					}
					errorEl.classList.remove('hidden');
				}
				document.getElementById('password').value = '';
			}

			submitBtn.textContent = originalText;
			submitBtn.disabled = false;
		});

		// === Logout ===
		document.getElementById('logout-btn')?.addEventListener('click', function() {
			showLogin();
		});
	</script>
</BaseLayout>
