---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import Sidebar from '../components/Sidebar.astro';
import Socials from '../components/Socials.astro';
import { getCollection } from 'astro:content';
import { SITE, SOCIALS } from '../config';
import { UI } from '../i18n/translations';

const lang = Astro.url.pathname.startsWith('/en/') ? 'en' : 'zh';
const t = UI[lang];
const prefix = lang === 'en' ? '/en' : '';

// Get all posts for the current language, excluding drafts
const posts = await getCollection('blog', ({ data }) => {
  return data.lang === lang && !data.draft;
});

// Sort by publication date
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Get all categories with counts
const categories = [...new Set(posts.map(post => post.data.category).filter(Boolean))];
const postCounts: Record<string, number> = {};
for (const cat of categories) {
  postCounts[cat] = posts.filter(p => p.data.category === cat).length;
}

// Get all tags
const allTags = posts.flatMap(post => post.data.tags);
const uniqueTags = [...new Set(allTags)];

const activeSocials = SOCIALS.filter(s => s.active);

const searchUrl = new URL(lang === 'en' ? '/en/search' : '/search', Astro.site).href + '?q={search_term_string}';

// Featured post (first one)
const featuredPost = sortedPosts[0];
// Remaining posts for the grid
const remainingPosts = sortedPosts.slice(1);

// Recent posts for sidebar
const recentPostsForSidebar = sortedPosts.slice(0, 5).map(post => ({
  title: post.data.title,
  pubDate: post.data.pubDate,
  href: `${prefix}/blog/${post.id.replace(/^(zh|en)\//, '')}`,
}));
---

<BaseLayout title={t.siteTitle} description={t.siteDesc} lang={lang}>
  <!-- WebSite Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": SITE.title,
    "url": SITE.website,
    "potentialAction": {
      "@type": "SearchAction",
      "target": searchUrl,
      "query-input": "required name=search_term_string"
    }
  })} />

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
        </svg>
        <span>{t.heroBadge}</span>
      </div>

      <h1 class="hero-title">
        {t.heroTitle}
      </h1>

      <div class="hero-actions">
        <a href={`${prefix}/blog`} class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
          </svg>
          {t.heroBrowseArticles}
        </a>
        <a href={`${prefix}/about`} class="btn btn-outline">
          {t.heroLearnMore}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Social Links -->
      {activeSocials.length > 0 && (
        <div class="hero-socials">
          <Socials />
        </div>
      )}

      <!-- Stats -->
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-number">{posts.length}</span>
          <span class="stat-label">{t.posts}</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">{categories.length}</span>
          <span class="stat-label">{t.categoryCount}</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">{uniqueTags.length}</span>
          <span class="stat-label">{t.tagCount}</span>
        </div>
      </div>
    </div>

    <!-- Hero Decoration -->
    <div class="hero-decoration">
      <div class="decoration-circle circle-1"></div>
      <div class="decoration-circle circle-2"></div>
      <div class="decoration-circle circle-3"></div>
      <div class="decoration-grid"></div>
    </div>
  </section>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="section featured-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">{t.featuredHighlight}</h2>
        </div>
        <FeaturedPost
          title={featuredPost.data.title}
          description={featuredPost.data.description}
          pubDate={featuredPost.data.pubDate}
          updatedDate={featuredPost.data.updatedDate}
          category={featuredPost.data.category}
          heroImage={featuredPost.data.heroImage}
          href={`${prefix}/blog/${featuredPost.id.replace(/^(zh|en)\//, '')}`}
          lang={lang}
        />
      </div>
    </section>
  )}

  <!-- Main Content: Posts + Sidebar -->
  <section class="section main-content">
    <div class="container">
      <div class="content-layout">
        <!-- Left: Posts List -->
        <div class="posts-column">
          <div class="section-header">
            <h2 class="section-title">{t.latestPosts}</h2>
            <a href={`${prefix}/blog`} class="section-link">
              {t.viewAll}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

          <ul class="posts-grid">
            {remainingPosts.slice(0, SITE.postPerIndex).map((post) => (
              <Card
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                updatedDate={post.data.updatedDate}
                category={post.data.category}
                tags={post.data.tags}
                heroImage={post.data.heroImage}
                href={`${prefix}/blog/${post.id.replace(/^(zh|en)\//, '')}`}
                lang={lang}
                variant="h3"
              />
            ))}
          </ul>
        </div>

        <!-- Right: Sidebar -->
        <Sidebar
          categories={categories}
          postCounts={postCounts}
          tags={uniqueTags}
          recentPosts={recentPostsForSidebar}
          lang={lang}
          prefix={prefix}
        />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-bg-primary) 0%, var(--color-bg-secondary) 100%);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background-color: var(--color-primary-light);
    color: var(--color-primary);
    border-radius: 9999px;
    font-size: var(--text-sm);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: var(--text-5xl);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--color-text-primary);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .hero-socials {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background-color: var(--color-border);
  }

  /* Hero Decoration */
  .hero-decoration {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .decoration-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
  }

  .circle-1 {
    width: 400px;
    height: 400px;
    background: var(--color-primary);
    top: -100px;
    right: -100px;
  }

  .circle-2 {
    width: 300px;
    height: 300px;
    background: var(--color-secondary);
    bottom: -50px;
    left: -50px;
  }

  .circle-3 {
    width: 200px;
    height: 200px;
    background: var(--color-accent);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .decoration-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
  }

  /* Sections */
  .section {
    padding: 4rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .section-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: 0;
    color: var(--color-text-primary);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .section-link:hover {
    gap: 0.75rem;
  }

  /* Main Content Layout */
  .content-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 2.5rem;
    align-items: flex-start;
  }

  /* Posts Grid */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .content-layout {
      grid-template-columns: 1fr;
    }

    .posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 3rem;
    }

    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-stats {
      gap: 1rem;
    }

    .stat-divider {
      display: none;
    }

    .section {
      padding: 3rem 0;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: var(--text-3xl);
    }
  }
</style>
