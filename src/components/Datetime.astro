---
export interface Props {
  pubDatetime: Date;
  modDatetime?: Date | null;
  size?: "sm" | "lg";
  lang?: "zh" | "en";
  class?: string;
}

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  lang = "zh",
  class: className = "",
} = Astro.props;

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = isModified ? modDatetime : pubDatetime;

const date = datetime.toLocaleDateString(lang === "zh" ? "zh-CN" : "en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
});
---

<div class:list={["datetime", `datetime-${size}`, className]}>
  <svg
    width={size === "lg" ? 20 : 16}
    height={size === "lg" ? 20 : 16}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
    <line x1="16" y1="2" x2="16" y2="6" />
    <line x1="8" y1="2" x2="8" y2="6" />
    <line x1="3" y1="10" x2="21" y2="10" />
  </svg>
  {
    isModified && (
      <span class="updated-label">
        {lang === "zh" ? "更新于" : "Updated:"}
      </span>
    )
  }
  <time datetime={datetime.toISOString()}>{date}</time>
</div>

<style>
  .datetime {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-tertiary);
  }

  .datetime svg {
    flex-shrink: 0;
  }

  .datetime-sm {
    font-size: var(--text-sm);
  }

  .datetime-lg {
    font-size: var(--text-base);
  }

  @media (min-width: 640px) {
    .datetime-lg {
      font-size: var(--text-lg);
    }
  }

  .updated-label {
    font-size: inherit;
  }
</style>
