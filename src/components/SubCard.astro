---
export interface Props {
  lang?: "zh" | "en";
}

const { lang = "zh" } = Astro.props;

const t = {
  title: lang === "zh" ? "工具" : "Tools",
  link1: lang === "zh" ? "免费订阅" : "Free Subs",
  link2: "Tolink",
  link3: "ABShare",
  link4: "ToShare",
  link5: "Allblue",
  link6: "Mikasa",
  desc: lang === "zh" ? "V2Ray / Clash" : "V2Ray / Clash",
};

const subPath = lang === "en" ? "/en/blog/sub" : "/blog/sub";
const tolinkPath = lang === "en" ? "/en/blog/tolink" : "/blog/tolink";
const absharePath = lang === "en" ? "/en/blog/abshare" : "/blog/abshare";
const tosharePath = lang === "en" ? "/en/blog/toshare" : "/blog/toshare";
const allbluePath = lang === "en" ? "/en/blog/allblue" : "/blog/allblue";
const mksharePath = lang === "en" ? "/en/blog/mkshare" : "/blog/mkshare";
---

<div class="sub-card">
  <span class="sub-label">{t.title}</span>
  <a href={subPath} class="sub-link">{t.link1}</a>
  <span class="sub-sep">|</span>
  <a href={tolinkPath} class="sub-link">{t.link2}</a>
  <span class="sub-sep">|</span>
  <a href={absharePath} class="sub-link">{t.link3}</a>
  <span class="sub-sep">|</span>
  <a href={tosharePath} class="sub-link">{t.link4}</a>
  <span class="sub-sep">|</span>
  <a href={allbluePath} class="sub-link">{t.link5}</a>
  <span class="sub-sep">|</span>
  <a href={mksharePath} class="sub-link">{t.link6}</a>
  <span class="sub-desc">{t.desc}</span>
</div>

<style>
  .sub-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .sub-label {
    opacity: 0.6;
  }

  .sub-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .sub-link:hover {
    color: var(--color-primary);
  }

  .sub-sep {
    opacity: 0.3;
  }

  .sub-desc {
    opacity: 0.4;
  }
</style>
