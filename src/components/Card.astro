---
import Datetime from "./Datetime.astro";

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  heroImage?: string;
  href: string;
  lang?: "zh" | "en";
  variant?: "h2" | "h3";
  featured?: boolean;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  heroImage,
  href,
  lang = "zh",
  variant: Heading = "h2",
  featured = false,
} = Astro.props;

// 估算阅读时间
const estimatedWords = Math.max(300, description.length * 8);
const readingTime = Math.max(1, Math.ceil(estimatedWords / (lang === 'zh' ? 400 : 200)));

// 判断是否为"新"文章（7天内发布）
const isNew = Date.now() - pubDate.valueOf() < 7 * 24 * 60 * 60 * 1000;

// 判断是否"已更新"（发布后7天以上且有更新）
const isUpdated = updatedDate && updatedDate !== pubDate &&
  Date.now() - updatedDate.valueOf() < 7 * 24 * 60 * 60 * 1000 &&
  Date.now() - pubDate.valueOf() > 7 * 24 * 60 * 60 * 1000;
---

<li class:list={["card", { featured }]}>
  <a href={href} class="card-link">
    {heroImage && (
      <div class="card-image">
        <img src={heroImage} alt={title} loading="lazy" decoding="async" width="400" height="225" />
        {category && <span class="card-category">{category}</span>}
        {isNew && <span class="card-badge badge-new">{lang === 'zh' ? '新' : 'NEW'}</span>}
        {isUpdated && <span class="card-badge badge-updated">{lang === 'zh' ? '更新' : 'UPDATED'}</span>}
        {featured && <span class="card-badge badge-featured">{lang === 'zh' ? '推荐' : 'FEATURED'}</span>}
      </div>
    )}
    <div class="card-content">
      <div class="card-meta-row">
        <Datetime pubDatetime={pubDate} modDatetime={updatedDate} lang={lang} />
        <span class="card-reading-time">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {readingTime}{lang === 'zh' ? '分钟' : 'min'}
        </span>
      </div>
      <Heading class="card-title">{title}</Heading>
      <p class="card-description">{description}</p>
      {tags.length > 0 && (
        <div class="card-tags">
          {tags.slice(0, 3).map(tag => (
            <span class="card-tag">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</li>

<style>
  .card {
    list-style: none;
    margin-bottom: 1.5rem;
    animation: cardFadeIn 0.5s ease both;
  }
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
  .card:nth-child(5) { animation-delay: 0.25s; }
  .card:nth-child(6) { animation-delay: 0.3s; }

  @keyframes cardFadeIn {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card.featured .card-link {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 1px var(--color-primary-light);
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
    background: var(--color-bg-primary);
  }

  .card-link:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background-color: var(--color-bg-tertiary);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .card-link:hover .card-image img {
    transform: scale(1.05);
  }

  .card-category {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.25rem 0.75rem;
    background-color: var(--color-primary);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-full);
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.2rem 0.6rem;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    border-radius: var(--radius-sm);
    text-transform: uppercase;
  }

  .badge-new {
    background-color: #10b981;
    color: white;
  }

  .badge-updated {
    background-color: #f59e0b;
    color: white;
  }

  .badge-featured {
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: white;
  }

  .card-content {
    padding: 1.5rem;
  }

  .card-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .card-meta-row :global(.datetime) {
    margin-bottom: 0;
  }

  .card-reading-time {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-tight);
    margin-bottom: 0.75rem;
    color: var(--color-text-primary);
    transition: color var(--transition-fast);
    text-wrap: balance;
  }

  .card-link:hover .card-title {
    color: var(--color-primary);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .card-tag {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    background-color: var(--color-bg-tertiary);
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius-full);
  }

  @media (max-width: 768px) {
    .card-image {
      height: 160px;
    }
  }
</style>
