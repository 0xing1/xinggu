---
export interface Props {
  categories: string[];
  postCounts: Record<string, number>;
  lang?: "zh" | "en";
  prefix?: string;
}

const { categories, postCounts, lang = "zh", prefix = "" } = Astro.props;

const title = lang === "zh" ? "文章分类" : "Categories";
---

<div class="sidebar-section">
  <h3 class="sidebar-heading">{title}</h3>
  <ul class="category-list">
    {categories.map((category) => (
      <li>
        <a href={`${prefix}/blog/category/${category}`} class="category-link">
          <span class="category-name">{category}</span>
          <span class="category-count">{postCounts[category] ?? 0}</span>
        </a>
      </li>
    ))}
  </ul>
</div>

<style>
  .sidebar-section {
    padding: 1.5rem;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
  }

  .sidebar-heading {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-primary);
  }

  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0;
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--color-border);
    transition: color var(--transition-fast), padding-left var(--transition-fast);
  }

  .category-link:last-child {
    border-bottom: none;
  }

  .category-link:hover {
    color: var(--color-primary);
    padding-left: 0.5rem;
    text-decoration: none;
  }

  .category-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    height: 1.5rem;
    padding: 0 0.375rem;
    background-color: var(--color-bg-tertiary);
    color: var(--color-text-tertiary);
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .category-link:hover .category-count {
    background-color: var(--color-primary-light);
    color: var(--color-primary);
  }
</style>
